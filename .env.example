# =============================================================================
# LedgerLock Environment Variables Template
# =============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in actual values for your environment
# 3. NEVER commit .env to version control
#
# For production deployments, these should be set via:
# - Kubernetes Secrets
# - Cloud Run environment variables
# - HashiCorp Vault
# - AWS Secrets Manager / Azure Key Vault / GCP Secret Manager
#
# =============================================================================

# ======================== DATABASE CONFIGURATION ========================
# PostgreSQL connection (Neon serverless in production)
DB_URL=jdbc:postgresql://localhost:5432/ledgerlock
DB_USER=postgres
DB_PASSWORD=<your-secure-database-password>

# ======================== JWT SECURITY ========================
# Generate with: openssl rand -base64 64
# MUST be at least 256 bits (32 bytes) for HS256 algorithm
JWT_SECRET=<your-256-bit-secret-key-base64-encoded>

# Token expiration (milliseconds)
# Production: 900000 (15 minutes)
# Development: 86400000 (24 hours)
JWT_EXPIRATION_MS=900000

# Refresh token expiration (days)
JWT_REFRESH_EXPIRATION_DAYS=7

# Maximum concurrent sessions per user
JWT_MAX_SESSIONS=5

# ======================== FIELD ENCRYPTION ========================
# AES-256-GCM encryption key for sensitive data
# Generate with: openssl rand -base64 32
# CRITICAL: Losing this key means encrypted data cannot be recovered
LEDGERLOCK_ENCRYPTION_KEY=<your-32-byte-base64-encoded-aes-key>

# ======================== REDIS CONFIGURATION ========================
# Distributed caching and rate limiting
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=<your-redis-password>

# ======================== OBSERVABILITY ========================
# OpenTelemetry distributed tracing
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SAMPLER_RATIO=1.0

# ======================== CLOUD DEPLOYMENT ========================
# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id

# Cloud Run configuration
CLOUD_RUN_REGION=us-central1
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=10

# ======================== FRAUD DETECTION ========================
# Configurable thresholds
FRAUD_VELOCITY_WINDOW_MINUTES=60
FRAUD_VELOCITY_MAX_TRANSACTIONS=10
FRAUD_LARGE_TRANSACTION_THRESHOLD=5000
FRAUD_VELOCITY_AMOUNT_THRESHOLD=10000

# ======================== APPLICATION PORT ========================
# Default Spring Boot port (Cloud Run uses PORT env var)
PORT=8080
