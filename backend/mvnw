#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper shell script for Unix
# ----------------------------------------------------------------------------
# This script downloads and runs the Maven Wrapper.
# It allows running Maven without having Maven installed globally.
#
# Usage: ./mvnw clean install
# ----------------------------------------------------------------------------

set -e

MAVEN_PROJECTBASEDIR="$(cd "$(dirname "$0")" && pwd)"
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"

# Download maven-wrapper.jar if it doesn't exist
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
    echo "Downloading Maven Wrapper..."
    mkdir -p "$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
    curl -o "$MAVEN_WRAPPER_JAR" "$WRAPPER_URL"
fi

# Run Maven
exec java \
  -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" \
  -Dwrapper.jar="$MAVEN_WRAPPER_JAR" \
  -jar "$MAVEN_WRAPPER_JAR" "$@"
